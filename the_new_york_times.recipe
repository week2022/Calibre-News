from calibre.web.feeds.news import BasicNewsRecipe

class NYTRSS(BasicNewsRecipe):
    title       = 'The New York Times (RSS)'
    description = 'Daily digest via official RSS (summary + link).'
    language    = 'en'
    encoding    = 'utf-8'

    oldest_article = 1
    max_articles_per_feed = 30
    use_embedded_content  = True
    no_stylesheets        = True
    remove_javascript     = True
    auto_cleanup          = True

    feeds = [
        ('Home Page', 'https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml'),
        ('World',     'https://rss.nytimes.com/services/xml/rss/nyt/World.xml'),
        ('Business',  'https://rss.nytimes.com/services/xml/rss/nyt/Business.xml'),
        ('Technology','https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml'),
        ('Opinion',   'https://rss.nytimes.com/services/xml/rss/nyt/Opinion.xml'),
    ]
