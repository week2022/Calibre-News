from calibre.web.feeds.news import BasicNewsRecipe

class FTRSS(BasicNewsRecipe):
    title       = 'Financial Times (RSS)'
    description = 'Daily digest via RSS (summary + link).'
    language    = 'en'
    encoding    = 'utf-8'

    oldest_article = 1
    max_articles_per_feed = 30
    use_embedded_content  = True
    no_stylesheets        = True
    remove_javascript     = True
    auto_cleanup          = True

    feeds = [
        ('World',     'https://www.ft.com/world?format=rss'),
        ('Markets',   'https://www.ft.com/markets?format=rss'),
        ('Companies', 'https://www.ft.com/companies?format=rss'),
        ('Tech',      'https://www.ft.com/technology?format=rss'),
        ('Opinion',   'https://www.ft.com/opinion?format=rss'),
    ]
