from calibre.web.feeds.news import BasicNewsRecipe

class WPRSS(BasicNewsRecipe):
    title       = 'The Washington Post (RSS)'
    description = 'Daily digest via RSS (summary + link).'
    language    = 'en'
    encoding    = 'utf-8'

    oldest_article = 1
    max_articles_per_feed = 30
    use_embedded_content  = True
    no_stylesheets        = True
    remove_javascript     = True
    auto_cleanup          = True

    feeds = [
        ('National', 'https://feeds.washingtonpost.com/rss/national'),
        ('World',    'https://feeds.washingtonpost.com/rss/world'),
        ('Politics', 'https://feeds.washingtonpost.com/rss/politics'),
        ('Business', 'https://feeds.washingtonpost.com/rss/business'),
        ('Tech',     'https://feeds.washingtonpost.com/rss/business/technology'),
    ]
