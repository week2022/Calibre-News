from calibre.web.feeds.news import BasicNewsRecipe

class NYTMix(BasicNewsRecipe):
    title = 'The New York Times (Mix)'
    language = 'en'
    max_articles_per_feed = 25
    oldest_article = 1

    # C方案核心：RSS做入口，抓不到全文也能保留摘要
    use_embedded_content = False

    # 可按需增减栏目
    feeds = [
        ('Top Stories', 'https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml'),
        ('World',       'https://rss.nytimes.com/services/xml/rss/nyt/World.xml'),
        ('Business',    'https://rss.nytimes.com/services/xml/rss/nyt/Business.xml'),
        ('Technology',  'https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml'),
    ]

    # 适度伪装 UA，提升“抓全文”成功率（仍可能被封，封了就回落到摘要）
    def get_browser(self, *args, **kwargs):
        br = super().get_browser(*args, **kwargs)
        br.addheaders = [
            ('User-Agent', 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 '
                           '(KHTML, like Gecko) Chrome/120.0 Safari/537.36'),
            ('Accept-Language', 'en-US,en;q=0.9'),
        ]
        return br

    # 轻量清理（抓到全文时用；抓不到也不影响摘要）
    remove_tags = [
        dict(name=['script', 'style', 'noscript']),
        dict(attrs={'id': ['comments', 'respond']})
    ]
